<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container">
    <div class="text-center mb-5">
      <h1 class="display-3">Cyber Crime Watch</h1>
      <p class="lead">Latest reports, analyses, and vulnerabilities from the wild.</p>
    </div>

    <div class="row g-4">
      <!-- Blog Post 1 -->
      <div class="col-md-4">
        <div class="card glass-card h-100">
          <div class="card-body">
            <h4 class="card-title text-info">Ransomware Syndicate Takedown</h4>
            <p class="card-text text-light">A notorious group known for encrypting hospital records was finally apprehended in a joint international operation.</p>
            <a href="#" class="btn btn-sm btn-glass">Read More</a>
          </div>
          <div class="card-footer bg-transparent border-0 text-muted small">
            Posted 2 days ago
          </div>
        </div>
      </div>
      
      <!-- Blog Post 2 -->
      <div class="col-md-4">
        <div class="card glass-card h-100">
          <div class="card-body">
            <h4 class="card-title text-info">The Rise of AI Phishing</h4>
            <p class="card-text text-light">Learn how attackers use LLMs to automate spear-phishing campaigns at a massive scale, rendering traditional filters useless.</p>
            <a href="#" class="btn btn-sm btn-glass">Read More</a>
          </div>
          <div class="card-footer bg-transparent border-0 text-muted small">
            Posted 5 days ago
          </div>
        </div>
      </div>

      <!-- Blog Post 3 -->
      <div class="col-md-4">
        <div class="card glass-card h-100">
          <div class="card-body">
            <h4 class="card-title text-info">Zero-Day in Popular Router</h4>
            <p class="card-text text-light">A critical unauthenticated RCE vulnerability has affected over 1 million home routing units. Patch immediately!</p>
            <a href="#" class="btn btn-sm btn-glass">Read More</a>
          </div>
          <div class="card-footer bg-transparent border-0 text-muted small">
            Posted 1 week ago
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
