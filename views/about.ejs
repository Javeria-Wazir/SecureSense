<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container">
    <div class="row align-items-center mb-5">
      <div class="col-md-6">
        <h1 class="display-4 text-info">About Us</h1>
        <p class="lead">SecureSense is an educational initiative dedicated to demonstrating cyber vulnerabilities.</p>
        <p>Our mission is to help developers and security analysts understand the importance of secure coding practices by interacting with live, exploitable examples.</p>
      </div>
      <div class="col-md-6">
        <div class="card glass-card">
          <div class="card-body">
            <h4 class="text-white">Why We Do It</h4>
            <p class="text-light text-opacity-75">
              The best way to learn how to patch a system is to understand how an attacker breaks it. We focus on exposing the mechanisms behind modern web exploits, from SQL Injection to Cross-Site Scripting.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
