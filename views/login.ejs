<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-6">
        <div class="card glass-card">
          <div class="card-header border-0 mt-2 text-center">
            <h3>Login to SecureSense</h3>
          </div>
          <div class="card-body">
            <% if (typeof error !== 'undefined') { %>
              <div class="alert alert-danger shadow-sm border-0 bg-danger text-white" role="alert">
                <%= error %>
              </div>
            <% } %>
            <form action="/login" method="POST">
              <!-- Week 5 Task: Add CSRF token to prevent CSRF attacks -->
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <!-- VULNERABILITY: Input Handling -->
                <input type="text" class="form-control" id="username" name="username" required>
              </div>
              <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input type="password" class="form-control" id="password" name="password" required>
              </div>
              <button type="submit" class="btn btn-info w-100 btn-glass">Login</button>
            </form>
            <div class="mt-3 text-center">
              <a href="/register" class="text-info text-decoration-none">Don't have an account? Register here.</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
