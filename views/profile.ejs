<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container mt-5">
    <div class="row">
      <div class="col-md-8 mx-auto">
        <div class="card glass-card">
          <div class="card-body text-center py-5">
            <h1 class="display-4 text-info mb-4">Welcome to your Profile!</h1>
            
            <!-- VULNERABILITY: Cross-Site Scripting (XSS) -->
            <!-- BEFORE: Using <%- %> in EJS renders the raw HTML. -->
            <!-- AFTER: Using <%= %> correctly escapes HTML to prevent XSS. -->
            <p class="lead text-white">Hello, <strong><%= username %></strong>!</p>
            
            <hr class="my-4 border-light opacity-25">
            <p class="text-white-50">This is your secure dashboard. (Or is it?)</p>

            <a href="/" class="btn btn-glass mt-3">Back to Home</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
